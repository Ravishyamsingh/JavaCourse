# ⚠️ SECURITY WARNING: This file contains sensitive credentials
# NEVER commit this file to version control
# NEVER share these credentials with anyone
# Rotate credentials immediately if exposed

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=3
GEMINI_RATE_LIMIT_PER_MINUTE=60

# Server Configuration
NODE_ENV=development
PORT=5000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database Configuration
MONGO_URL=mongodb://localhost:27017/java-course
MONGODB_URI=mongodb://localhost:27017/java-course
DB_NAME=java-course

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# JWT Configuration (MUST be at least 32 characters in production)
JWT_ACCESS_SECRET=your_jwt_access_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_characters_long
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=Java Course <your_email@gmail.com>

# Admin Configuration
ADMIN_EMAILS=admin@example.com
ADMIN_EMAIL_DOMAINS=example.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Compiler Configuration
PAIZA_API_BASE=https://api.paiza.io
PAIZA_API_KEY=guest
JAVA_SOURCE_LIMIT_BYTES=40000
JAVA_OUTPUT_LIMIT_BYTES=20000
COMPILER_POLL_INTERVAL_MS=1200

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security
CORS_ORIGIN=http://localhost:5173
CSRF_PROTECTION=true
HELMET_ENABLED=true
BCRYPT_SALT_ROUNDS=12
SESSION_SECRET=your_session_secret_minimum_32_characters_long
